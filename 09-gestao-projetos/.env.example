# Supabase edge function URL (find in: Supabase Dashboard > Project Settings > API > URL)
SUPABASE_URL=https://avpfuhwmvlofncczqyfm.supabase.co

# Supabase anon key — safe for local scripts calling edge functions
# Find in: Supabase Dashboard > Project Settings > API > anon / public key
SUPABASE_ANON_KEY=

# Internal key — must match INTERNAL_API_KEY secret set in Supabase edge functions
# Find in: Supabase Dashboard > Edge Functions > Secrets > INTERNAL_API_KEY
INTERNAL_API_KEY=

# Zoho portal ID — auto-discovered on first run (controller.py portals)
# Leave blank on first run; controller will print it.
ZOHO_PORTAL_ID=

# Optional: Zoho Projects domain override (default: https://projectsapi.zoho.eu)
# ZOHO_PROJECTS_DOMAIN=https://projectsapi.zoho.eu
